---
interface Props { kind: 'progress' | 'sweep' | 'ring' | 'spinner' | 'dots' | 'skeleton'; value?: number; }
const { kind, value = 64 } = Astro.props;
const SEG = 14;
const lit = Math.round((value / 100) * SEG);
---
{kind === 'progress' && (
  <div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:11px;">
      <span class="rf-mono" style="font-size:9px;color:var(--rf-ink-faint);">PROGRESS</span>
      <span class="rf-display" style="font-weight:700;font-size:16px;color:var(--rf-ink);text-shadow:var(--rf-glow-white);">{value}%</span>
    </div>
    <div style="display:flex;gap:3px;">
      {Array.from({ length: SEG }).map((_, i) => (
        <span style={`flex:1;height:9px;border-radius:2px;background:${i < lit ? 'var(--rf-led)' : 'var(--rf-border)'};${i < lit ? 'box-shadow:var(--rf-glow-white);' : ''}`}></span>
      ))}
    </div>
  </div>
)}
{kind === 'sweep' && (
  <div style="position:relative;height:6px;border-radius:9999px;background:var(--rf-border);overflow:hidden;">
    <span style="position:absolute;top:0;left:-40%;width:40%;height:100%;border-radius:9999px;background:var(--rf-led);box-shadow:var(--rf-glow-white);animation:bar-sweep 1.4s ease-in-out infinite;"></span>
  </div>
)}
{kind === 'ring' && (
  <div style="position:relative;width:64px;height:64px;">
    <svg width="64" height="64" viewBox="0 0 64 64">
      <circle cx="32" cy="32" r="28" stroke="var(--rf-border)" stroke-width="5" fill="none" />
      <circle cx="32" cy="32" r="28" stroke="var(--rf-led)" stroke-width="5" fill="none" stroke-linecap="round"
        stroke-dasharray="175.9" stroke-dashoffset={175.9 * (1 - value / 100)} transform="rotate(-90 32 32)" />
    </svg>
    <span class="rf-display" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;color:var(--rf-ink);">{value}</span>
  </div>
)}
{kind === 'spinner' && (
  <svg width="40" height="40" viewBox="0 0 40 40" style="animation:spin .9s linear infinite;"><circle cx="20" cy="20" r="16" stroke="var(--rf-border)" stroke-width="4" fill="none"/><path d="M20 4a16 16 0 0 1 16 16" stroke="var(--rf-accent)" stroke-width="4" fill="none" stroke-linecap="round"/></svg>
)}
{kind === 'dots' && (
  <div style="display:flex;gap:7px;align-items:center;">
    {[0, .16, .32, .48].map((d) => (
      <span style={`width:9px;height:9px;border-radius:50%;background:var(--rf-led);animation:dot-seq 1.1s ease-in-out infinite;animation-delay:${d}s;`}></span>
    ))}
  </div>
)}
{kind === 'skeleton' && (
  <div style="display:flex;flex-direction:column;gap:8px;">
    {[80, 60, 70].map((w) => (
      <span style={`height:10px;width:${w}%;border-radius:3px;background:var(--rf-border);animation:skeleton-pulse 1.4s ease-in-out infinite;`}></span>
    ))}
  </div>
)}
