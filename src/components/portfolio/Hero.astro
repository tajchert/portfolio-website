---
import Tag from './Tag.astro';
---
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));gap:clamp(28px,4vw,52px);align-items:center;margin-bottom:clamp(64px,9vw,104px);">

  <!-- identity -->
  <div>
    <h1 style="margin:0;font-family:var(--rf-font-display),'Space Mono',monospace;font-weight:600;font-size:clamp(46px,9.5vw,92px);line-height:.86;letter-spacing:.01em;color:#f4f4f2;">Michał<br>Tajchert</h1>
    <div style="margin-top:22px;display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;">
      <span style="font-size:clamp(17px,2.4vw,21px);font-weight:500;letter-spacing:-.01em;color:#f4f4f2;">Chief Technology Officer</span>
      <span style="font-family:var(--rf-font-jp);font-size:13px;color:#6c6c6c;white-space:nowrap;flex-shrink:0;">最高技術責任者</span>
    </div>
    <div style="margin-top:8px;font-family:var(--rf-font-mono);font-size:12px;letter-spacing:.06em;color:#8a8a82;">@mtajchert &nbsp;·&nbsp; WARSAW, PL</div>
    <p style="margin:22px 0 0;max-width:500px;font-size:clamp(15px,2vw,17.5px);line-height:1.55;letter-spacing:-.01em;color:#c4c4be;text-wrap:pretty;">I build high-agency product engineering teams that excel at speed and ownership to <span style="color:#f4f4f2;">build the best.</span></p>
    <div style="margin-top:24px;display:flex;flex-wrap:wrap;gap:8px;">
      <Tag accent>ENGINEERING LEADERSHIP</Tag>
      <Tag>PRODUCT TECH</Tag>
      <Tag>MOBILE PLATFORMS</Tag>
      <Tag>DATA</Tag>
    </div>
  </div>

  <!-- terminal (muted — recedes behind the identity column) -->
  <div style="border:1px solid #161616;border-radius:12px;background:#070707;overflow:hidden;opacity:.62;">
    <div style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid #151515;background:#0b0b0b;">
      <span style="display:flex;gap:6px;align-items:center;">
        <span style="width:9px;height:9px;border-radius:50%;background:#2a2a2a;"></span>
        <span style="width:9px;height:9px;border-radius:50%;background:#2a2a2a;"></span>
        <span style="width:9px;height:9px;border-radius:50%;background:#3a3a3a;"></span>
      </span>
      <span style="font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.1em;color:#5a5a54;margin-left:4px;">mtajchert — zsh — 96×24</span>
    </div>
    <div style="padding:18px 18px 20px;font-family:var(--rf-font-mono);font-size:13px;line-height:1.85;color:#6c6c66;">
      <div><span style="color:#7a7a72;">mtajchert@nothing</span><span style="color:#4a4a44;">:~$</span> cat ~/.philosophy</div>
      <div style="color:#8a8a82;">&gt; the best way to understand it is to build it.</div>
      <div style="margin-top:6px;"><span style="color:#7a7a72;">mtajchert@nothing</span><span style="color:#4a4a44;">:~$</span> ls ~/building</div>
      <div style="color:#5a5a54;">&gt; <a href="https://kanarek.app" target="_blank" rel="noopener" class="pf-link-hover-underline">kanarek.app</a>&nbsp;&nbsp;open-source/&nbsp;&nbsp;data-viz/&nbsp;&nbsp;experiments/</div>
      <div style="margin-top:6px;"><span style="color:#7a7a72;">mtajchert@nothing</span><span style="color:#4a4a44;">:~$</span> history | grep -c commit</div>
      <div style="color:#8a8a82;">&gt; 15+ years of shipping</div>
      <div style="margin-top:6px;"><span style="color:#7a7a72;">mtajchert@nothing</span><span style="color:#4a4a44;">:~$</span> <span style="display:inline-block;width:9px;height:16px;background:#4a4a44;vertical-align:-3px;animation:cursor-blink 1.1s steps(1) infinite;"></span></div>
    </div>
  </div>
</div>
