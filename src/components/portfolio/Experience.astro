---
const roles = [
  { title: 'Chief Technology Officer', badge: 'NOW', badgeAccent: true, meta: 'Lite e-Commerce · Feb 2025 — present · Warsaw', body: 'Leading software, design, and data for Żabka Jush and Delio: engineering direction, product delivery, and team health.', accentNode: true },
  { title: 'Engineering Manager', badge: 'ECOM', meta: 'MODIVO SA · May 2022 — Dec 2024', body: 'Managed mobile teams for MODIVO and eObuwie apps across 19 markets, plus the Backend-For-Frontend layer and cross-department delivery.' },
  { title: 'Mobile Technology Leader', meta: 'MODIVO SA · Nov 2021 — May 2022', body: 'Set mobile engineering direction during a fast-growth phase: architecture, team practices, and delivery standards.' },
  { title: 'Mobile Technology Leader', badge: 'BANKING', meta: 'BlueSoft · Oct 2020 — Oct 2021 · Warsaw', body: 'Led mobile technology and the Android team for Raiffeisen Ukraine while supporting wider mobile initiatives inside BlueSoft.' },
  { title: 'Technology Business Development Manager', badge: 'FINTECH', meta: 'DXC Technology · Feb 2019 — Sep 2020 · Warsaw', body: 'Owned technology, delivery, and client-facing work for BLIK in the UAE and IKO at PKO BP, bridging architecture, senior teams, and business needs.' },
  { title: 'Android Team Lead @ Raiffeisen', badge: 'BANKING', meta: 'BlueSoft · Jul 2017 — Jan 2019 · Warsaw', body: 'Led a six-person Android team building a new banking app while maintaining Mobilny Portfel and coordinating the BNP mobile merge.' },
  { title: 'Startups - Brand24, Yawn, Icelytics, 12Hours', meta: '2015 — 2017 · Warsaw / Toronto', body: 'Built and led early product teams across analytics, mobile apps, and consumer products; mixed Android delivery with founder-level ownership.' },
  { title: 'Software Engineer', meta: 'Polidea · Jul 2014 — Apr 2015 · Warsaw', body: 'Professional software engineering in a mobile-focused software house, building Android products for clients.' },
  { title: 'Android Developer', meta: 'BrandCare · Jul 2013 — Oct 2013 · Warsaw', body: 'Early commercial Android work, including Banamo, a privacy-focused safer community app.', dim: true },
];
---
<section id="log" style="margin-bottom:clamp(56px,8vw,96px);scroll-margin-top:64px;">
  <div style="display:flex;align-items:baseline;gap:14px;margin-bottom:8px;flex-wrap:wrap;">
    <h2 style="font-family:var(--rf-font-mono);font-size:12px;font-weight:700;letter-spacing:.28em;color:#f4f4f2;">03 / EXPERIENCE</h2>
    <span style="font-family:var(--rf-font-jp);font-size:13px;color:#6c6c6c;white-space:nowrap;flex-shrink:0;">経歴</span>
  </div>
  <div style="height:1px;background:#1a1a1a;margin-bottom:28px;"></div>

  <div style="display:flex;flex-direction:column;">
    {roles.map((r, i) => {
      const last = i === roles.length - 1;
      const nodeColor = r.accentNode ? '#ff4d12' : r.dim ? '#3a3a3a' : '#f4f4f2';
      const nodeGlow = r.accentNode ? '0 0 10px rgba(255,77,18,.8)' : r.dim ? 'none' : '0 0 8px rgba(255,255,255,.4)';
      return (
        <div style={`display:grid;grid-template-columns:auto 1fr;gap:clamp(14px,3vw,28px);${last ? '' : 'padding-bottom:28px;'}`}>
          <div style="display:flex;flex-direction:column;align-items:center;">
            <span style={`width:11px;height:11px;border-radius:50%;background:${nodeColor};box-shadow:${nodeGlow};`}></span>
            {!last && <span style="flex:1;width:1px;background:#222;margin-top:6px;"></span>}
          </div>
          <div>
            <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:5px;">
              <h3 style="font-size:clamp(17px,2.4vw,20px);font-weight:600;color:#f4f4f2;">{r.title}</h3>
              {r.badge && (
                <span style={`font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.1em;border-radius:999px;padding:2px 9px;${r.badgeAccent ? 'color:#ff8a5a;border:1px solid #5a2a18;' : 'color:#cfcfca;border:1px solid #2a2a2a;'}`}>{r.badge}</span>
              )}
            </div>
            <div style="font-family:var(--rf-font-mono);font-size:12px;letter-spacing:.04em;color:#9a9a92;margin-bottom:10px;">{r.meta}</div>
            <p style="margin:0;font-size:14px;line-height:1.6;color:#8a8a82;max-width:560px;text-wrap:pretty;">{r.body}</p>
          </div>
        </div>
      );
    })}
  </div>
</section>
