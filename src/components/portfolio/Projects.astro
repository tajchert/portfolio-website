---
import Tag from './Tag.astro';

// ── Tier 1: shipped ────────────────────────────────────────────────────────
const highlighted = [
  {
    name: 'Kanarek.app',
    href: 'https://kanarek.app',
    desc: 'Air-quality monitoring app aggregating Polish smog data across mobile platforms.',
    tags: ['MOBILE', 'DATA', 'AIR QUALITY'],
    stats: [{ v: '200k+', l: 'active users' }, { v: '4.8/5', l: 'rating' }],
  },
  {
    name: 'WaitingDots',
    href: 'https://github.com/tajchert/WaitingDots',
    desc: 'Android loading animation library built around bouncing dots, shipped as a small reusable UI component.',
    tags: ['KOTLIN', 'ANDROID', 'OSS'],
    stats: [{ v: '700+', l: '★' }, { v: 'MIT', l: 'license' }],
  },
  {
    name: 'Nammu',
    href: 'https://github.com/tajchert/Nammu',
    desc: 'Android runtime-permission helper for cleaner permission checks, callbacks, monitoring, and Android M-era app flows.',
    tags: ['KOTLIN', 'ANDROID', 'PERMISSIONS'],
    stats: [{ v: '700+', l: '★' }, { v: 'MIT', l: 'license' }],
  },
];

// ── Tier 2: also ───────────────────────────────────────────────────────────
const shipped = [
  { name: 'BusWear', href: 'https://github.com/tajchert/BusWear', desc: 'EventBus support for Android Wear and mobile apps with synchronized event buses.', stack: 'JAVA · ANDROID WEAR · OSS' },
  { name: 'ExceptionWear', href: 'https://github.com/tajchert/ExceptionWear', desc: 'Android Wear exception-handling library for making wearable app failures easier to manage.', stack: 'JAVA · ANDROID WEAR · OSS' },
  { name: 'RuntimePermissionWorkshop', href: 'https://github.com/tajchert/RuntimePermissionWorkshop', desc: 'Workshop material for teaching Android runtime permissions through practical examples.', stack: 'JAVA · WORKSHOP · ANDROID' },
];

// ── Tier 3: experiments · POC ──────────────────────────────────────────────
// Data-driven so adding more is just appending here.
const experiments = [
  { name: '12Hours', tag: 'APP', note: 'Calendar-as-analog-clock widget; 100k users in three days after Reddit traction.', href: '' },
  { name: 'SGH Daily', tag: 'STUDENTS', note: 'University app with timetable, news, and cancelled-class alerts; 10k+ users.', href: '' },
  { name: 'Warsaw Hacks', tag: '1ST PRIZE', note: 'Civic identity-verification concept using one-time codes for public employees.', href: 'https://spidersweb.pl/bizblog/siup-weryfikacja-tozsamosci/' },
];
---
<section id="work" style="margin-bottom:clamp(56px,8vw,96px);scroll-margin-top:64px;">
  <div style="display:flex;align-items:baseline;gap:14px;margin-bottom:14px;flex-wrap:wrap;">
    <span style="font-family:var(--rf-font-mono);font-size:13px;font-weight:700;letter-spacing:.28em;color:var(--rf-accent);">02 / PROJECTS</span>
    <span style="font-family:var(--rf-font-jp);font-size:13px;color:#6c6c6c;white-space:nowrap;flex-shrink:0;">制作物</span>
  </div>
  <h2 style="margin:0 0 30px;font-family:var(--rf-font-display);font-weight:600;font-size:clamp(32px,5.4vw,56px);line-height:.93;letter-spacing:.01em;color:#f4f4f2;">Pixel Pushing</h2>

  <!-- Tier 1: shipped -->
  <div style="font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.2em;color:#7a7a72;margin-bottom:14px;">SHIPPED · 主要</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,300px),1fr));gap:16px;margin-bottom:16px;">
    {highlighted.map((p) => (
      <a href={p.href} target="_blank" rel="noopener" class="pf-card-accent" style="border:1px solid #242424;border-radius:14px;background:#0d0d0d;padding:22px;display:block;position:relative;overflow:hidden;">
        <div style="position:absolute;top:0;right:0;width:120px;height:120px;background-image:radial-gradient(rgba(255,90,30,.18) 1px,transparent 1.4px);background-size:8px 8px;pointer-events:none;"></div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
          <span style="font-family:var(--rf-font-mono);font-size:9px;letter-spacing:.2em;color:#0b0b0b;background:#ff4d12;border-radius:999px;padding:4px 10px;font-weight:700;">★ HIGHLIGHT</span>
          <span style="font-family:var(--rf-font-mono);font-size:10px;color:#6c6c6c;">↗</span>
        </div>
        <h3 style="font-family:var(--rf-font-display);font-weight:700;font-size:30px;line-height:1;color:#f4f4f2;margin-bottom:12px;overflow-wrap:anywhere;">{p.name}</h3>
        <p style="margin:0 0 18px;font-size:14px;line-height:1.6;color:#9a9a92;">{p.desc}</p>
        <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px;">
          {p.tags.map((t) => <Tag size="xs">{t}</Tag>)}
        </div>
        <div style="display:flex;gap:16px;font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.06em;color:#7a7a72;">
          {p.stats.map((s) => (
            <span><span style="color:#f4f4f2;font-family:var(--rf-font-display);font-weight:700;font-size:13px;">{s.v}</span> {s.l}</span>
          ))}
        </div>
      </a>
    ))}
  </div>

  <!-- Tier 2: also -->
  <div style="font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.2em;color:#7a7a72;margin:34px 0 14px;">ALSO · 出荷済み</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,220px),1fr));gap:14px;margin-bottom:40px;">
    {shipped.map((p) => (
      <a href={p.href} target="_blank" rel="noopener" class="pf-card-soft" style="border:1px solid #1f1f1f;border-radius:12px;background:#0a0a0a;padding:18px;display:block;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#f4f4f2;box-shadow:0 0 7px rgba(255,255,255,.5);"></span>
          <span style="font-family:var(--rf-font-mono);font-size:10px;color:#6c6c6c;">↗</span>
        </div>
        <h3 style="font-family:var(--rf-font-display);font-weight:700;font-size:21px;color:#f4f4f2;margin-bottom:8px;overflow-wrap:anywhere;">{p.name}</h3>
        <p style="margin:0 0 12px;font-size:13px;line-height:1.55;color:#8a8a82;text-wrap:pretty;">{p.desc}</p>
        <div style="font-family:var(--rf-font-mono);font-size:9px;letter-spacing:.1em;color:#7a7a72;">{p.stack}</div>
      </a>
    ))}
  </div>

  <!-- Tier 3: experiments · POC -->
  <div style="display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin:0 0 8px;">
    <span style="font-family:var(--rf-font-mono);font-size:10px;letter-spacing:.2em;color:#ff8a5a;">EXPERIMENTS · POC · 実験</span>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,248px),1fr));gap:10px;">
    {experiments.map((x) => {
      const Wrapper = x.href ? 'a' : 'div';
      const linkAttrs = x.href ? { href: x.href, target: '_blank', rel: 'noopener' } : {};
      return (
        <Wrapper {...linkAttrs} class="pf-card-faint" style="border:1px solid #161616;border-radius:11px;background:#080808;padding:14px 16px;display:flex;gap:12px;align-items:flex-start;">
          <span style="width:6px;height:6px;border-radius:50%;background:#3a3a3a;flex-shrink:0;margin-top:7px;"></span>
          <div style="min-width:0;">
            <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:4px;">
              <span style="font-family:var(--rf-font-display);font-weight:700;font-size:15px;color:#f4f4f2;white-space:nowrap;">{x.name}</span>
              <span style="font-family:var(--rf-font-mono);font-size:8px;letter-spacing:.12em;color:#8a8a82;border:1px solid #242424;border-radius:999px;padding:2px 7px;white-space:nowrap;">{x.tag}</span>
            </div>
            <div style="font-size:12.5px;line-height:1.5;color:#8a8a82;text-wrap:pretty;">{x.note}</div>
          </div>
        </Wrapper>
      );
    })}
  </div>
</section>
