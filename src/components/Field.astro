---
interface Props {
  type?: 'text' | 'search' | 'select' | 'error' | 'code';
  label?: string;
  value?: string;
  placeholder?: string;
  focused?: boolean;
  error?: string;
  codeDigits?: string[];   // for type=code, e.g. ['2','7','','']
  codeActive?: number;     // index of focused code cell
}
const { type = 'text', label, value = '', placeholder = '', focused = false, error, codeDigits = ['2','7','',''], codeActive = 2 } = Astro.props;

const boxBase = 'height:50px;border-radius:11px;display:flex;align-items:center;padding:0 15px;background:var(--rf-surface-inset);';
const boxBorder = focused
  ? 'border:1px solid var(--rf-ink);box-shadow:0 0 0 3px color-mix(in srgb, var(--rf-ink) 8%, transparent);'
  : type === 'error'
  ? 'border:1px solid var(--rf-accent);background:color-mix(in srgb, var(--rf-accent) 8%, var(--rf-surface-inset));'
  : 'border:1px solid var(--rf-border);';
const caret = '<span style="width:2px;height:20px;background:var(--rf-accent);box-shadow:var(--rf-glow-orange);animation:rec-blink 1.1s steps(1) infinite;"></span>';
const led = '<span style="width:8px;height:8px;border-radius:50%;background:var(--rf-led);box-shadow:var(--rf-glow-white);"></span>';
---
<div>
  {label && <div class="rf-mono" style={`font-size:9px;color:${type === 'error' ? 'var(--rf-accent-soft)' : focused ? 'var(--rf-ink)' : 'var(--rf-ink-faint)'};margin-bottom:9px;`}>{label}</div>}

  {type === 'code' ? (
    <div style="display:flex;gap:9px;">
      {codeDigits.map((d, i) => (
        <div style={`flex:1;height:60px;border-radius:11px;background:var(--rf-surface-inset);background-image:radial-gradient(var(--rf-dot-color) 1px,transparent 1.3px);background-size:7px 7px;display:flex;align-items:center;justify-content:center;${i === codeActive ? 'border:1px solid var(--rf-ink);box-shadow:0 0 0 3px color-mix(in srgb, var(--rf-ink) 8%, transparent);' : 'border:1px solid var(--rf-border-2);'}`}>
          {d ? <span class="rf-display" style="font-weight:700;font-size:26px;color:var(--rf-ink);text-shadow:var(--rf-glow-white);">{d}</span>
            : i === codeActive ? <Fragment set:html={caret} />
            : <span style="width:6px;height:6px;border-radius:50%;background:var(--rf-border-2);"></span>}
        </div>
      ))}
    </div>
  ) : (
    <div style={boxBase + boxBorder + (focused ? 'gap:1px;' : type === 'search' ? 'gap:11px;' : '')}>
      {type === 'search' && (
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="6" stroke="var(--rf-ink-faint)" stroke-width="2"/><path d="M20 20l-3.6-3.6" stroke="var(--rf-ink-faint)" stroke-width="2" stroke-linecap="round"/></svg>
      )}
      <span style={`font-size:14px;letter-spacing:-.01em;color:${(placeholder && !value) ? 'var(--rf-ink-faint)' : 'var(--rf-ink)'};`}>{value || placeholder}</span>
      {focused && <Fragment set:html={caret} />}
      <span style="flex:1;"></span>
      {focused && <Fragment set:html={led} />}
      {type === 'select' && <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="var(--rf-ink-faint)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>}
      {type === 'error' && <span style="width:16px;height:16px;border-radius:50%;border:1.5px solid var(--rf-accent);display:inline-flex;align-items:center;justify-content:center;font-family:var(--rf-font-mono);font-size:10px;font-weight:700;color:var(--rf-accent);">!</span>}
    </div>
  )}
  {error && <div class="rf-mono" style="font-size:9px;letter-spacing:.04em;text-transform:none;color:var(--rf-accent-soft);margin-top:7px;">{error}</div>}
</div>
